{
  "name": "prismforge",
  "version": "0.1.0",
  "private": true,
  "description": "Global open-source token platform for multi-brand, multi-mode design systems.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "bootstrap": "corepack enable pnpm && pnpm install",
    "build": "turbo run build",
    "test": "turbo run test && node --test ./scripts/test/*.test.mjs && node ./scripts/verify-examples.mjs",
    "validate": "turbo run validate",
    "guard:breaking": "node ./scripts/token-breaking-guard.mjs",
    "release:preflight": "node ./scripts/release-preflight.mjs",
    "dev:studio": "pnpm --filter @prismforge/token-studio dev",
    "prismforge": "pnpm --filter @prismforge/token-cli prismforge",
    "release:guard:stable": "node ./scripts/release-guard.mjs --channel stable",
    "release:guard:next": "node ./scripts/release-guard.mjs --channel next",
    "release:guard:alpha": "node ./scripts/release-guard.mjs --channel alpha",
    "release:guard:beta": "node ./scripts/release-guard.mjs --channel beta",
    "release:guard:rc": "node ./scripts/release-guard.mjs --channel rc",
    "release:guard:canary": "node ./scripts/release-guard.mjs --channel canary",
    "release:guard:custom": "node ./scripts/release-guard.mjs --channel custom --dist-tag preview",
    "test:studio:e2e": "pnpm --filter @prismforge/token-studio test:e2e"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.8",
    "turbo": "^2.1.3"
  }
}

