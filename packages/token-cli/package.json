{
  "name": "@prismforge/token-cli",
  "version": "0.7.1",
  "type": "module",
  "description": "CLI for validating, building, and exporting PrismForge tokens.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prismforge/prismforge.git"
  },
  "bugs": {
    "url": "https://github.com/prismforge/prismforge/issues"
  },
  "homepage": "https://github.com/prismforge/prismforge#readme",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "prismforge": "./src/cli.js"
  },
