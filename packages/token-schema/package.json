{
  "name": "@prismforge/token-schema",
  "version": "0.1.0",
  "type": "module",
  "description": "Schema, types, and validation utilities for PrismForge tokens.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prismforge/prismforge.git"
  },
  "bugs": {
    "url": "https://github.com/prismforge/prismforge/issues"
  },
  "homepage": "https://github.com/prismforge/prismforge#readme",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./src/index.js",
    "./schema/token.schema.json": "./src/schema/token.schema.json",
    "./schema/token-set.schema.json": "./src/schema/token-set.schema.json",
    "./types": "./src/types.d.ts"
  },
  "scripts": {
    "build": "node -e \"console.log('token-schema build: no-op')\"",
